
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id
  name          String
  email         String
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  sessions      Session[]
  accounts      Account[]

  universityId          String?
  university            University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
  onboardingCompletedAt DateTime?

  leetcodeUsername                  String?
  leetcodeVerified                  Boolean   @default(false)
  leetcodeVerifiedAt                DateTime?
  leetcodeVerificationCode          String?
  leetcodeVerificationCodeExpiresAt DateTime?

  leetcodeTotalSolved  Int?
  leetcodeEasySolved   Int?
  leetcodeMediumSolved Int?
  leetcodeHardSolved   Int?
  leetcodeRanking      Int?
  leetcodeContestRating       Float?
  leetcodeContestGlobalRanking Int?
  leetcodeBadges              Json?
  leetcodeSyncStatus          LeetcodeSyncStatus @default(IDLE)
  leetcodeSyncError           String?
  leetcodeLastSyncAttemptAt   DateTime?
  leetcodeLastSyncedAt DateTime?

  publicProfileEnabled Boolean @default(false)
  publicProfileHandle  String?

  leetcodeSnapshots LeetcodeSnapshot[]

  ownedGroups      Group[]           @relation("GroupOwner")
  groupMemberships GroupMembership[]
  createdChallenges GroupChallenge[] @relation("ChallengeCreator")
  challengeParticipations ChallengeParticipant[]
  platformRole PlatformRole @default(USER)
  submittedClubApplications ClubApplication[] @relation("ClubApplicationSubmitter")
  reviewedClubApplications ClubApplication[] @relation("ClubApplicationReviewer")
  clubMembershipApplications ClubMembershipApplication[] @relation("ClubMembershipApplicant")
  reviewedMembershipApplications ClubMembershipApplication[] @relation("ClubMembershipReviewer")
  clubAnnouncements ClubAnnouncement[]
  auditEvents AuditEvent[]
  notifications Notification[] @relation("NotificationRecipient")
  notificationsActed Notification[] @relation("NotificationActor")

  @@unique([email])
  @@unique([leetcodeUsername])
  @@unique([publicProfileHandle])
  @@index([universityId])
  @@map("user")
}

model LeetcodeSnapshot {
  id     String @id
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  totalSolved   Int
  easySolved    Int
  mediumSolved  Int
  hardSolved    Int
  contestRating Float?
  ranking       Int?

  capturedAt DateTime @default(now())
  capturedOn DateTime @db.Date

  @@unique([userId, capturedOn])
  @@index([userId, capturedAt])
  @@map("leetcode_snapshot")
}

enum LeetcodeSyncStatus {
  IDLE
  PENDING
  SUCCESS
  FAILED

  @@map("leetcode_sync_status")
}

enum OwnershipType {
  PUBLIC
  PRIVATE_NONPROFIT
  PRIVATE_FOR_PROFIT

  @@map("ownership_type")
}

enum ChallengeMetric {
  TOTAL_SOLVED
  HARD_SOLVED
  CONTEST_RATING

  @@map("challenge_metric")
}

enum ChallengeBaselineKind {
  START_SNAPSHOT
  JOIN_FALLBACK
  PENDING

  @@map("challenge_baseline_kind")
}

enum PlatformRole {
  USER
  ADMIN
}

enum GroupKind {
  CASUAL
  OFFICIAL_CLUB
}

enum GroupRole {
  OWNER
  ADMIN
  OFFICER
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  REMOVED
  LEFT
  BLOCKED
}

enum ClubApplicationStatus {
  PENDING
  CHANGES_REQUESTED
  APPROVED
  REJECTED
  WITHDRAWN
}

enum ClubMembershipApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WITHDRAWN
}

enum AnnouncementVisibility {
  PUBLIC
  MEMBERS
}

model University {
  id            String         @id
  unitId        String?
  name          String
  slug          String
  city          String
  state         String
  website       String?
  ownershipType OwnershipType?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  users         User[]
  groups        Group[]
  clubApplications ClubApplication[]

  @@unique([slug])
  @@unique([unitId])
  @@index([state])
  @@index([name])
  @@map("university")
}

model Group {
  id          String   @id
  name        String
  ownerId     String
  owner       User     @relation("GroupOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  inviteToken String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  kind             GroupKind @default(CASUAL)
  universityId     String?
  university       University? @relation(fields: [universityId], references: [id], onDelete: SetNull)
  slug             String? @unique
  description      String?
  contactEmail     String?
  websiteUrl       String?
  discordUrl       String?
  githubUrl        String?
  logoUrl          String?
  approvedAt       DateTime?
  approvedById     String?
  suspendedAt      DateTime?
  suspensionReason String?

  memberships GroupMembership[]
  challenges   GroupChallenge[]
  clubApplications ClubApplication[]
  membershipApplications ClubMembershipApplication[]
  announcements ClubAnnouncement[]
  auditEvents AuditEvent[]
  notifications Notification[]

  @@unique([inviteToken])
  @@index([ownerId])
  @@map("group")
}

model GroupChallenge {
  id          String          @id
  groupId     String
  group       Group           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdById String
  createdBy   User            @relation("ChallengeCreator", fields: [createdById], references: [id], onDelete: Cascade)
  title       String
  description String?
  metric      ChallengeMetric
  startsOn    DateTime        @db.Date
  endsOn      DateTime        @db.Date
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  participants ChallengeParticipant[]

  @@index([groupId, startsOn])
  @@index([groupId, endsOn])
  @@map("group_challenge")
}

model ChallengeParticipant {
  id          String         @id
  challengeId String
  challenge   GroupChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  userId      String
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt    DateTime       @default(now())

  baselineKind          ChallengeBaselineKind @default(PENDING)
  baselineTotalSolved   Int?
  baselineHardSolved    Int?
  baselineContestRating Float?
  baselineCapturedAt    DateTime?

  finalMetricValue Float?
  finalDelta       Float?
  finalizedAt      DateTime?

  @@unique([challengeId, userId])
  @@index([userId])
  @@map("challenge_participant")
}

model GroupMembership {
  id      String @id
  groupId String
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId  String
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  role GroupRole @default(MEMBER)
  status MembershipStatus @default(ACTIVE)
  publicOfficerVisible Boolean @default(true)
  endedAt DateTime?
  removedById String?
  removalReason String?

  @@unique([groupId, userId])
  @@index([userId])
  @@map("group_membership")
}

model ClubApplication {
  id String @id
  groupId String
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  submittedById String
  submittedBy User @relation("ClubApplicationSubmitter", fields: [submittedById], references: [id], onDelete: Cascade)
  universityId String
  university University @relation(fields: [universityId], references: [id], onDelete: Restrict)
  status ClubApplicationStatus @default(PENDING)
  proposedName String
  requestedSlug String
  description String
  officialWebsiteUrl String
  facultyAdvisorName String
  facultyAdvisorEmail String
  contactEmail String
  githubUrl String?
  discordUrl String?
  evidenceNote String
  submittedAt DateTime @default(now())
  reviewedAt DateTime?
  reviewedById String?
  reviewedBy User? @relation("ClubApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, status])
  @@index([status, submittedAt])
  @@index([requestedSlug])
  @@map("club_application")
}

model ClubMembershipApplication {
  id String @id
  groupId String
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  userId String
  user User @relation("ClubMembershipApplicant", fields: [userId], references: [id], onDelete: Cascade)
  status ClubMembershipApplicationStatus @default(PENDING)
  message String?
  submittedAt DateTime @default(now())
  reviewedAt DateTime?
  reviewedById String?
  reviewedBy User? @relation("ClubMembershipReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewNote String?
  withdrawnAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupId, status, submittedAt])
  @@index([userId, groupId, submittedAt])
  @@map("club_membership_application")
}

model ClubAnnouncement {
  id String @id
  groupId String
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)
  authorId String
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)
  title String
  body String
  visibility AnnouncementVisibility
  publishedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  archivedAt DateTime?

  @@index([groupId, visibility, publishedAt])
  @@map("club_announcement")
}

model AuditEvent {
  id String @id
  actorId String
  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)
  groupId String?
  group Group? @relation(fields: [groupId], references: [id], onDelete: SetNull)
  action String
  targetType String
  targetId String?
  metadata Json?
  createdAt DateTime @default(now())

  @@index([groupId, createdAt])
  @@index([actorId, createdAt])
  @@map("audit_event")
}

model Notification {
  id          String           @id
  recipientId String
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actorId     String?
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)
  type        NotificationType
  groupId     String?
  group       Group?           @relation(fields: [groupId], references: [id], onDelete: Cascade)
  challengeId String?
  entityType  String?
  entityId    String?
  title       String
  body        String?
  href        String?
  metadata    Json?
  createdAt   DateTime         @default(now())
  readAt      DateTime?

  @@index([recipientId, createdAt])
  @@index([recipientId, readAt])
  @@map("notification")
}

enum NotificationType {
  CLUB_APPLICATION_APPROVED
  CLUB_APPLICATION_REJECTED
  CLUB_APPLICATION_CHANGES_REQUESTED
  CLUB_MEMBERSHIP_APPROVED
  CLUB_MEMBERSHIP_REJECTED
  CLUB_ANNOUNCEMENT_PUBLISHED
  CLUB_ROLE_CHANGED
  CLUB_MEMBER_REMOVED
  GROUP_MEMBER_JOINED
  GROUP_MEMBER_REMOVED
  CHALLENGE_CREATED
  CHALLENGE_STARTED
  CHALLENGE_ENDING_SOON
  CHALLENGE_FINISHED

  @@map("notification_type")
}

model Session {
  id        String   @id
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}
